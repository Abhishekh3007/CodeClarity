generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Repository {
  id           String    @id @default(uuid())
  userId       String
  repoName     String
  repoUrl      String
  lastAnalyzed DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews      Review[]

  @@index([userId])
  @@map("repositories")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  password     String
  githubId     String?
  createdAt    DateTime     @default(now())
  repositories Repository[]

  @@map("users")
}

model Review {
  id         String     @id @default(uuid())
  repoId     String
  fileName   String
  issueType  String
  severity   String
  suggestion String
  createdAt  DateTime   @default(now())
  repository Repository @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@index([repoId])
  @@map("reviews")
}

model GitHubConnection {
  id           String   @id @default(uuid())
  userId       String   @unique
  githubUserId String
  accessToken  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([githubUserId])
  @@map("github_connections")
}
